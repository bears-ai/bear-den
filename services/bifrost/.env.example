# Bifrost gateway — environment for the Coolify/Docker service
# Provider keys are referenced from config.json via env.* (see services/bifrost/config.json).

# Required if the OpenAI provider block is present in config.json
OPENAI_API_KEY=sk-...

# Optional: add an anthropic block to config.json, then set:
# ANTHROPIC_API_KEY=sk-ant-...

# HTTP bind (Docker / Coolify)
APP_HOST=0.0.0.0
APP_PORT=8080

# Logging
LOG_LEVEL=info
LOG_STYLE=json
