# Listen port inside the container
PORT=3030

# Letta HTTP API (same origin Den uses for persistence) — required for the SDK subprocess
LETTA_BASE_URL=http://bear-letta:8283
LETTA_API_KEY=SETME
# Self-hosted memfs (Letta in root compose -> `bears-memfs-manager:8285` for git HTTP)
LETTA_MEMFS_LOCAL=1

# Runtime provisioner mode
BEAR_RUNTIME_PROVISIONER=local

# Optional shared secret: Den sends `Authorization: Bearer <token>` to Codepool
CODEPOOL_INTERNAL_TOKEN=

# Session pool
POOL_TTL_SECS=600
POOL_MAX_ENTRIES=256
