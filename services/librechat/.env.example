# LibreChat Configuration for BEARS Stack
# Based on LibreChat v0.7.x configuration

#==================================================#
#               Server Configuration               #
#==================================================#

HOST=0.0.0.0
PORT=3080

# MongoDB (Coolify-managed or external)
MONGO_URI=mongodb://bears-mongodb:27017/LibreChat

# MeiliSearch for search functionality
MEILI_HOST=http://bears-meilisearch:7700
MEILI_MASTER_KEY=DrhYf7zENyR6AlUCKmnz0eYASOQdl6zxH7s7MKFSfFCt

# Domain configuration for Coolify
DOMAIN_CLIENT=https://your-coolify-domain.com
DOMAIN_SERVER=https://your-coolify-domain.com

# Trust proxy for Coolify reverse proxy
TRUST_PROXY=1

#==================================================#
#               AI Model Integration               #
#==================================================#

# Use Letta as the primary agent orchestration layer
# LibreChat will connect to Letta for all agent interactions
LETTA_URL=http://bears-letta:8283
LETTA_SERVER_PASS=your-letta-admin-password-here

# Note: Model access is handled through Letta's LiteLLM integration
# No direct API keys needed in LibreChat

#==================================================#
#               Authentication                     #
#==================================================#

# Enable multi-user authentication
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false

# JWT Configuration
JWT_SECRET=your-secure-jwt-secret-here
JWT_REFRESH_SECRET=your-secure-refresh-secret-here

# Session Configuration
SESSION_TIMEOUT=7d

#==================================================#
#               Memory / context                   #
#==================================================#
# Letta handles agent memory. Shared knowledge: Cabinet (Outline) via Den — PLAN.md

#==================================================#
#               File Upload Configuration          #
#==================================================#

# Enable file uploads
ALLOW_FILE_UPLOAD=true

# File size limits
FILE_SIZE_LIMIT=10MB
IMAGE_SIZE_LIMIT=5MB

#==================================================#
#               Security Configuration             #
#==================================================#

# Rate limiting
RATE_LIMIT_CONVO=10
RATE_LIMIT_TIME=1

# Moderation (optional)
OPENAI_MODERATION=false

#==================================================#
#               UI Configuration                   #
#==================================================#

# Interface settings
INTERFACE_UI=true
INTERFACE_CONFIG=true

#==================================================#
#               Debug Configuration                #
#==================================================#

DEBUG_LOGGING=false
DEBUG_CONSOLE=false

#==================================================#
#               Coolify-Specific Settings          #
#==================================================#

# User and Group IDs for file permissions
UID=1000
GID=1000

#==================================================#
#               Optional Integrations              #
#==================================================#

# Email configuration (for password reset, etc.)
EMAIL_SERVICE=smtp
EMAIL_HOST=your-smtp-host
EMAIL_PORT=587
EMAIL_ENCRYPTION=tls
EMAIL_USERNAME=your-email@domain.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM_NAME=BEARS LibreChat
EMAIL_FROM=noreply@yourdomain.com

# Web search (optional)
SEARCH=true
SERPER_API_KEY=your-serper-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key
JINA_API_KEY=your-jina-api-key