# Qdrant Service Environment Variables

# Qdrant works with defaults - no environment variables required

# Optional: Performance Tuning
# QDRANT__SERVICE__GRPC_PORT=6334
# QDRANT__SERVICE__HTTP_PORT=6333
# QDRANT__STORAGE__OPTIMIZERS__MAX_SEGMENT_SIZE=200000
# QDRANT__STORAGE__OPTIMIZERS__MEMMAP_THRESHOLD=50000

# Optional: Logging
# QDRANT__LOG_LEVEL=INFO

# Optional: API Authentication
# QDRANT__SERVICE__API_KEY=<generate-secure-api-key>
