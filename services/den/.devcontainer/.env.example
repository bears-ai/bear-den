# Copy to `.env` in this directory (`cp .env.example .env`). Used by docker compose for `app` + `db`.
# `app` uses `network_mode: service:db`, so Postgres is reachable at localhost:5432.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trestle

DATABASE_URL=postgres://postgres:postgres@localhost:5432/trestle?sslmode=disable
RUN_WEB=true
RUN_API=false
RUN_WORKERS=false
PORT=3000
API_PORT=3001
