{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            users.id AS id,\n            username,\n            display_name,\n            email,\n            (email_configs.verified_at IS NOT NULL) AS email_verified,\n            theme,\n            week_start_day,\n            users.created_at AS created\n        FROM users\n        LEFT JOIN email_configs\n            ON users.id = email_configs.user_id\n            AND email_configs.active = true\n        WHERE\n            users.id = $1\n        ",
