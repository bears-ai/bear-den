# Onyx API Server Environment Variables

# PostgreSQL Configuration (Coolify-managed database)
POSTGRES_HOST=<your-coolify-postgres-service-name>
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<generate-secure-password>
POSTGRES_DB=onyx

# Redis Configuration
REDIS_HOST=bears-redis
REDIS_PORT=6379

# Qdrant Configuration
QDRANT_HOST=bears-qdrant
QDRANT_PORT=6333

# OpenAI API (for embeddings)
OPENAI_API_KEY=sk-...

# Authentication (disabled for single-user deployment)
AUTH_TYPE=disabled

# Optional: Advanced Configuration
# LOG_LEVEL=info
# WEB_DOMAIN=yourdomain.com
# EMBEDDING_MODEL=text-embedding-ada-002
