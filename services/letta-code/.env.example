# Letta Code harness (`letta server`) — pair with services/letta and Den.
# Copy to `.env` beside docker-compose.yaml for local `docker compose` (substitution).
# Coolify: same keys are listed under `environment` in docker-compose.yaml for UI discovery.

# Required: self-hosted Letta HTTP API (no trailing slash).
LETTA_BASE_URL=http://bears-letta:8283

# Required for unattended / self-hosted: same Bearer Letta expects (often LETTA_SERVER_PASS on Letta).
LETTA_API_KEY=<same-as-LETTA_SERVER_PASS>

# Shown in Letta Code environment picker; optional.
ENV_NAME=bears-prod

# Optional: verbose logs
# LETTA_DEBUG=1
