# Open WebUI + Letta session helper — env example (NOT part of BEARS stack; see DEN_ARCHITECTURE.md)

LETTA_API_URL=http://bears-letta:8283/v1
LETTA_SERVER_PASS=your-letta-password-here

# Session strategy: user | chat | hybrid
SESSION_STRATEGY=user

# Session storage: file (simplest), postgres, or redis if you run Redis
SESSION_STORAGE=file
# SESSION_STORAGE=redis
# REDIS_URL=redis://your-redis:6379
# POSTGRES_URL=postgresql://user:pass@host:5432/sessions

OPENWEBUI_API_URL=http://bears-openwebui:3000
