# Open WebUI + Letta Integration Configuration
# Copy this to your Open WebUI service environment variables

# Letta API Configuration
LETTA_API_URL=http://bears-letta:8283/v1
LETTA_SERVER_PASS=your-letta-password-here

# Session Management Strategy
# Options: "user" (one agent per user), "chat" (one agent per chat), "hybrid"
SESSION_STRATEGY=user

# Session Storage Backend
# Options: "redis" (recommended), "postgres", "file" (development only)
SESSION_STORAGE=redis
REDIS_URL=redis://bears-redis:6379

# Alternative: PostgreSQL storage
# POSTGRES_URL=postgresql://user:password@bears-postgres:5432/sessions

# Knowledgebase Integration (optional, for saving session history)
KNOWLEDGEBASE_URL=http://bears-knowledgebase:8080

# Open WebUI Configuration
# These should be set in your Open WebUI service
OPENWEBUI_API_URL=http://bears-openwebui:3000
OPENWEBUI_API_KEY=your-openwebui-api-key

