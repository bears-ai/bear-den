# Letta Service Environment Variables
# Shared knowledge: Cabinet (Outline) via Den — see docs/planning/PLAN.md

# Bifrost (model gateway) — OpenAI-compatible API
LLM_API_URL=http://bear-bifrost:8080/v1

# Bifrost GitOps config in this repo does not require a gateway master key by default.
# If you enable Bifrost governance/virtual keys, set the credential Letta must send
# (often the same variable Letta uses for the OpenAI client) per Bifrost docs.

# Model Configuration
MODEL_NAME=gpt-4

# Letta Server
LETTA_SERVER_PORT=8283
LETTA_SERVER_PASS=<generate-secure-password>

# Embeddings (Letta often calls OpenAI directly; keep a valid key here)
OPENAI_API_KEY=sk-...

# Optional:
# LETTA_SERVER_HOST=0.0.0.0
# LOG_LEVEL=INFO
