# Letta Service Environment Variables
# Shared knowledge: Cabinet (Outline) via Den — see PLAN.md

# LiteLLM Integration
LLM_API_URL=http://bears-litellm:4000/v1

# If LiteLLM uses a master key, set the same value here:
# LITELLM_MASTER_KEY=sk-litellm-...

# Model Configuration
MODEL_NAME=gpt-4

# Letta Server
LETTA_SERVER_PORT=8283
LETTA_SERVER_PASS=<generate-secure-password>

# Embeddings (or route via LiteLLM)
OPENAI_API_KEY=sk-...

# Optional:
# LETTA_SERVER_HOST=0.0.0.0
# LOG_LEVEL=INFO
