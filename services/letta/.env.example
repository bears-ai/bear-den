# Letta Service Environment Variables

# Onyx Integration
ONYX_URL=http://bears-onyx:8080

# LiteLLM Integration
LLM_API_URL=http://bears-litellm:4000/v1

# Model Configuration
MODEL_NAME=gpt-4

# Letta Server Configuration
LETTA_SERVER_PORT=8283
# Generate with: openssl rand -base64 32
LETTA_SERVER_PASS=<generate-secure-password>

# OpenAI API Key (for embeddings - can also use via LiteLLM)
OPENAI_API_KEY=sk-...

# Optional: Advanced Configuration
# LETTA_SERVER_HOST=0.0.0.0
# LOG_LEVEL=INFO
