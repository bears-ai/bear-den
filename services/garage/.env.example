# Garage has no environment-variable driven config — all settings live in garage.toml.
# This file documents the secrets you must replace in garage.toml before deploying.
#
# rpc_secret:     openssl rand -hex 32
# admin_token:    openssl rand -base64 32
# metrics_token:  openssl rand -base64 32
#
# After deploy, create a bucket and API key via the garage CLI:
#   garage bucket create bears-media
#   garage key create den-service-key
#   garage bucket allow --read --write bears-media --key den-service-key
