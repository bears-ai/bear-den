{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            t.id,\n            t.token,\n            t.scopes,\n            t.expires_at,\n            t.created_at,\n            c.client_id,\n            c.name as client_name\n        FROM oauth_access_tokens t\n        INNER JOIN oauth_clients c ON t.client_id = c.id\n        WHERE t.user_id = $1 AND NOT t.revoked AND t.expires_at > NOW()\n        ORDER BY t.created_at DESC\n        ",
