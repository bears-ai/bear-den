  "query": "\n        SELECT id, code, client_id, user_id, redirect_uri, scopes,\n               expires_at, used as \"used!\", created_at,\n               code_challenge, code_challenge_method\n        FROM oauth_authorization_codes\n        WHERE code = $1 AND client_id = $2 AND redirect_uri = $3\n        ",
