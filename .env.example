# Required deployment-specific values
JWT_SECRET=SETME
LETTA_SERVER_PASS=SETME
OPENAI_API_KEY=SETME
WEB_SERVER_URL=SETME

# Optional compose profiles
# COMPOSE_PROFILES=bundled

# Den database
# Managed Postgres is preferred. If you use COMPOSE_PROFILES=bundled, set this to:
# postgres://bears:bears@bears-postgres:5432/den?sslmode=disable
DATABASE_URL=SETME
DB_MAX_CONNECTIONS=5
DB_ACQUIRE_TIMEOUT_SECS=3
DB_IDLE_TIMEOUT_SECS=600
SQLX_MIGRATE_IGNORE_MISSING=false

# Letta pgvector database
# Use postgresql://, not postgres://.
# If you use COMPOSE_PROFILES=bundled, set this to:
# postgresql://bears:bears@bears-letta-postgres:5432/letta
LETTA_PG_URI=SETME

# Bifrost model gateway
BIFROST_IMAGE=bears-bifrost:configured
BIFROST_APP_HOST=0.0.0.0
BIFROST_APP_PORT=8080
BIFROST_LOG_LEVEL=info
BIFROST_LOG_STYLE=json
BIFROST_BASE_URL=http://bears-bifrost:8080
LLM_API_URL=http://bears-bifrost:8080/v1

# Letta API server
LETTA_BASE_URL=http://bears-letta:8283
LETTA_SERVER_PORT=8283
LETTA_SERVER_HOST=0.0.0.0
LETTA_REDIS_HOST=bears-redis
LETTA_REDIS_PORT=6379
LETTA_MEMFS_SERVICE_URL=http://bears-memfs-manager:8285
LETTA_MEMFS_LOCAL=1
MODEL_NAME=gpt-4

# Memory Manager / memfs API
MEMFS_MANAGER_PORT=8285
MEMFS_MANAGER_BIND=0.0.0.0
MEMFS_BASE=/root/.letta/memfs/repository
MEMFS_DEFAULT_ORG=org-default

# Codepool harness
CODEPOOL_IMAGE=ghcr.io/theartificial/codepool:latest
CODEPOOL_PULL_POLICY=always
POOL_PORT=3030
CODEPOOL_BASE_URL=http://bears-codepool:3030
CODEPOOL_INTERNAL_TOKEN=
BEAR_RUNTIME_PROVISIONER=local
POOL_TTL_SECS=600
POOL_MAX_ENTRIES=256

# Den web/API service
DEN_IMAGE=ghcr.io/theartificial/den:latest
DEN_PULL_POLICY=always
DEN_PORT=3000
DEN_API_PORT=3001
APP_DISPLAY_NAME=BEARS
APP_SLUG=bears-den
RUN_WEB=true
RUN_API=false
RUN_WORKERS=false
RUST_LOG=info
API_SERVER_URL=https://api.bears.artificial.design
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=true
TEMPLATES_DIR=src/web/templates

# Optional Den pair-role web search provider.
# Set DEN_SEARCH_PROVIDER=brave and BRAVE_SEARCH_API_KEY to enable den.web.search.
DEN_SEARCH_PROVIDER=
BRAVE_SEARCH_API_KEY=
DEN_SEARCH_MAX_RESULTS=5

# Den email
MAIL_FROM_ADDRESS=noreply@bears.artificial.design
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Den S3-compatible object storage
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=garage
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=true

# Den GHCR status checks
GITHUB_PACKAGES_TOKEN=
GHCR_PACKAGES_OWNER=
GHCR_PACKAGES_OWNER_KIND=

# Letta volume backup profile
LETTA_VOLUME_BACKUP_CRON="0 4 * * *"
SCALEWAY_BACKUP_BUCKET=
SCALEWAY_BACKUP_PREFIX=bears-stack/volumes/bears-letta-data
SCALEWAY_ACCESS_KEY=
SCALEWAY_SECRET_KEY=
SCALEWAY_S3_ENDPOINT=s3.fr-par.scw.cloud
SCALEWAY_REGION=fr-par
