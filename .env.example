# Required secrets
JWT_SECRET=replace-with-a-long-random-secret
LETTA_SERVER_PASS=replace-with-a-secure-letta-password

# Optional compose profiles
# COMPOSE_PROFILES=bundled

# Database
DATABASE_URL=postgres://bears:bears@bear-postgres:5432/den?sslmode=disable
LETTA_PG_URI=

# Bifrost model gateway
BIFROST_APP_HOST=0.0.0.0
BIFROST_APP_PORT=8080
BIFROST_LOG_LEVEL=info
BIFROST_LOG_STYLE=json
BIFROST_BASE_URL=http://bear-bifrost:8080
LLM_API_URL=http://bear-bifrost:8080/v1
MODEL_NAME=gpt-4
OPENAI_API_KEY=

# Memory Manager / memfs API
MEMFS_MANAGER_PORT=8285
MEMFS_MANAGER_BIND=0.0.0.0
MEMFS_BASE=/root/.letta/memfs/repository
MEMFS_DEFAULT_ORG=org-default
LETTA_MEMFS_SERVICE_URL=http://bears-memfs-manager:8285

# Letta API server
LETTA_BASE_URL=http://bear-letta:8283
LETTA_API_BASE_URL=
LETTA_SERVER_PORT=8283
LETTA_SERVER_HOST=0.0.0.0
LETTA_REDIS_HOST=bear-redis
LETTA_REDIS_PORT=6379
LETTA_MEMFS_LOCAL=1

# Bears Pool / Codepool harness
CODEPOOL_IMAGE=ghcr.io/theartificial/codepool:latest
POOL_PORT=3030
CODEPOOL_BASE_URL=http://bear-codepool:3030
CODEPOOL_INTERNAL_TOKEN=
CODEPOOL_DISABLE_MEMFS=
BEAR_RUNTIME_PROVISIONER=local
POOL_TTL_SECS=600
POOL_MAX_ENTRIES=256

# Bears Den web/API service
DEN_IMAGE=ghcr.io/theartificial/den:latest
DEN_PORT=3000
DEN_API_PORT=3001
DEN_PUBLISH_PORT=3000
APP_DISPLAY_NAME=BEARS
APP_SLUG=bears-den
RUN_WEB=true
RUN_API=false
RUN_WORKERS=false
RUST_LOG=info
WEB_SERVER_URL=http://localhost:3000
API_SERVER_URL=https://api.bears.artificial.design
SESSION_COOKIE_DOMAIN=
MAIL_FROM_ADDRESS=noreply@bears.artificial.design
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
TEMPLATES_DIR=src/web/templates

# Den database/runtime tuning
SQLX_MIGRATE_IGNORE_MISSING=false
DB_MAX_CONNECTIONS=5
DB_ACQUIRE_TIMEOUT_SECS=3
DB_IDLE_TIMEOUT_SECS=600

# Den S3-compatible object storage
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=garage
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=true

# Den GHCR status checks
GITHUB_PACKAGES_TOKEN=
GHCR_PACKAGES_OWNER=
GHCR_PACKAGES_OWNER_KIND=org

# Letta volume backup profile
LETTA_VOLUME_BACKUP_CRON="0 4 * * *"
SCALEWAY_BACKUP_BUCKET=
SCALEWAY_BACKUP_PREFIX=bear-stack/volumes/bear-letta-data
SCALEWAY_ACCESS_KEY=
SCALEWAY_SECRET_KEY=
SCALEWAY_S3_ENDPOINT=s3.fr-par.scw.cloud
SCALEWAY_REGION=fr-par
