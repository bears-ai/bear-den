# API Keys for LLM Providers
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Letta API Authentication
LETTA_API_KEY=your-secure-letta-api-key-here

# Optional: Den operator checks against the model gateway (when implemented)
# BIFROST_BASE_URL=http://bear-bifrost:8080

# Root `docker-compose.yaml` — optional bundled Postgres (`bear-postgres`, profile `bundled`).
# Compose does not use `POSTGRES_*` env vars (avoids Coolify generating extra fields); bundled DB
# credentials are fixed in `docker-compose.yaml`. Prefer a managed database:
# COMPOSE_PROFILES=   (leave unset unless you want the bundled container)
# DATABASE_URL=postgres://user:pass@your-managed-host:5432/den?sslmode=require
