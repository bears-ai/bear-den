#!/bin/sh
set -eu

BIN="/usr/local/bin/bears-acp-adapter"

if [ ! -x "$BIN" ]; then
  echo "BEARS ACP adapter was installed, but $BIN is not executable." >&2
  exit 1
fi

# Avoid running network/config checks here; installs should succeed before the user has credentials.
"$BIN" --version >/dev/null 2>&1 || {
  echo "BEARS ACP adapter was installed, but --version failed." >&2
  exit 1
}

cat <<'MESSAGE'
BEARS ACP adapter installed successfully.

Next steps:
  1. Configure your ACP client to run /usr/local/bin/bears-acp-adapter.
  2. Provide DEN_API_URL, BEAR_SLUG, and DEN_TOKEN in the client environment.
  3. Run /usr/local/bin/bears-acp-adapter doctor from the same environment to validate setup.
MESSAGE

exit 0
