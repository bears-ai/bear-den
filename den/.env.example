# Runtime environment — hello world / smoke deploy
#
# Copy to `.env` for local runs (`cargo run` loads `.env` via dotenvy), or set
# these keys in your orchestrator (Kubernetes, Docker `-e`, systemd `Environment=`, etc.).
#
# PostgreSQL dependency
# ---------------------
# The app does not start postgres for you. You must provision Postgres, create a
# database, and apply migrations under `migrations/` before the process will run
# successfully (e.g. `sqlx migrate run` with this DATABASE_URL).

DATABASE_URL=postgres://postgres:postgres@localhost:5432/trestle?sslmode=disable

# Service toggles — enable at least one or the process will do little useful work.
RUN_WEB=true
RUN_API=false
RUN_WORKERS=false

PORT=3000
API_PORT=3001

# Optional: canonical URLs (defaults are localhost in non-production builds)
# WEB_SERVER_URL=http://localhost:3000
# API_SERVER_URL=http://localhost:3001

# Optional: session cookie Domain (production builds only). Omit for host-only cookies.
# SESSION_COOKIE_DOMAIN=.example.com

# Optional mail — leave empty for hello world
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# Optional: template path override (usually only for custom images/layouts)
# TEMPLATES_DIR=src/web/templates
