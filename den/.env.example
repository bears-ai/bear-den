# Runtime environment — hello world / smoke deploy
#
# Copy to `.env` for local runs (`cargo run` loads `.env` via dotenvy), or set
# these keys in your orchestrator (Kubernetes, Docker `-e`, systemd `Environment=`, etc.).
#
# PostgreSQL dependency
# ---------------------
# The app does not start postgres for you. Provision Postgres and create a database
# (empty is fine). On startup, `den` applies SQLx migrations under `migrations/` to
# this DATABASE_URL automatically.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/trestle?sslmode=disable

# Service toggles — enable at least one or the process will do little useful work.
RUN_WEB=true
RUN_API=false
RUN_WORKERS=false

PORT=3000
API_PORT=3001

# Branding (human title, PWA id / short name). Forks should set these.
# APP_DISPLAY_NAME=BEARS Den
# APP_SLUG=bear-den

# Optional: canonical public URLs (no trailing slash). Non-production defaults to http://localhost:{PORT|API_PORT}.
# Production builds default to this repo’s deployment hostname; override for your fork:
# WEB_SERVER_URL=https://bears.artificial.design
# API_SERVER_URL=https://api.bears.artificial.design
# WEB_SERVER_URL=http://localhost:3000
# API_SERVER_URL=http://localhost:3001

# Optional: RFC 5322 From address for outbound mail (default noreply@<WEB host> when host is not localhost, else unset fallback in code).
# MAIL_FROM_ADDRESS=noreply@bears.artificial.design

# Optional: session cookie Domain (production builds only). Omit for host-only cookies.
# SESSION_COOKIE_DOMAIN=.example.com

# Optional mail — leave empty for hello world
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=

# Optional: template path override (usually only for custom images/layouts)
# TEMPLATES_DIR=src/web/templates

# OAuth JWT signing (HS256). Required when RUN_API=true, or when the binary is built with `--features production`
# (Coolify / release images use production). Web-only local runs may omit this; a dev default is used only if the API is off.
# JWT_SECRET=replace-with-a-long-random-secret

# Database pool tuning (defaults are fine for most single-instance deployments).
# DB_MAX_CONNECTIONS=5
# DB_ACQUIRE_TIMEOUT_SECS=3
# DB_IDLE_TIMEOUT_SECS=600

# SQLx migrations: default is strict (every row in `_sqlx_migrations` must match files in `migrations/`).
# Set only for documented recovery when the DB lists migrations that were renamed/removed from the repo:
# SQLX_MIGRATE_IGNORE_MISSING=true

# Letta — persistence API (provisioning, conversation list, message history).
# Non-production: leave unset to skip Letta. Production images default to http://bear-letta:8283 when unset (Docker stack).
# Local dev: http://localhost:8283
# LETTA_BASE_URL=http://bear-letta:8283
# LETTA_API_KEY=
# Optional: same URL as Letta’s Memory Manager (git) — enables “Private memory (git)” on bear details (latest commit only). Docker stack: http://bear-mem-manager:8285
# LETTA_MEMFS_SERVICE_URL=http://bear-mem-manager:8285

# Codepool — Letta Code SDK harness (required when RUN_WEB=true; non-empty URL).
# Non-production: set explicitly when RUN_WEB=true (e.g. http://localhost:3030). Production images default to http://bear-codepool:3030.
# CODEPOOL_BASE_URL=http://bear-codepool:3030
# CODEPOOL_INTERNAL_TOKEN=

# S3-compatible object storage — Garage (artifacts: agent outputs, uploads, routine files — not in Letta). Leave endpoint empty to disable.
# See ../../docs/artifacts-garage-adr.md — Cabinet/Outline uses bucket bears-cabinet (separate; Phase 2+).
# S3_ENDPOINT=http://localhost:3900
# S3_BUCKET=bears-artifacts
# S3_REGION=garage
# S3_ACCESS_KEY_ID=<garage key id>
# S3_SECRET_ACCESS_KEY=<garage secret key>
# S3_PUBLIC_URL=http://localhost:3900
# S3_FORCE_PATH_STYLE=true

# Optional: GitHub Packages (GHCR) — when set, `GET /status` compares running Den/Codepool `git_sha` to registry tags
# GITHUB_PACKAGES_TOKEN=<PAT with read:packages>
# GHCR_PACKAGES_OWNER=your-org-or-user
# GHCR_PACKAGES_OWNER_KIND=org

# Optional: Bifrost gateway — Den uses it for `/status` stack probes when set (e.g. http://bear-bifrost:8080).
# BIFROST_BASE_URL=http://localhost:8080

# Optional: Letta Postgres URI — when set, `/status` runs SELECT 1 against it (same URI Letta uses).
# Prefer postgresql:// over postgres:// (see services/letta/COOLIFY_DEPLOY.md and services/preflight).
# LETTA_PG_URI=postgresql://user:pass@host:5432/letta

# Optional on Den: when set, `/status` validates LLM_API_URL shape (mirrors compose preflight).
# LLM_API_URL=http://bear-bifrost:8080/v1
