{
  "name": "bears",
  "dockerComposeProjectName": "bears_zed",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "runServices": ["app", "db"],
  "workspaceFolder": "/workspaces",
  "shutdownAction": "stopCompose",
  "forwardPorts": [3000, 3001, 5432],
  "remoteEnv": {
    "PATH": "/usr/local/cargo/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "bash /workspaces/.devcontainer/post-create.sh",
  "mounts": [
    {
      "source": "${localWorkspaceFolder}/.opencode/auth.json",
      "target": "/root/.opencode/auth.json",
      "type": "bind",
    },
  ],
}
